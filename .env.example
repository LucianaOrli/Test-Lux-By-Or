# Configurações do Langfuse para tracing de LLM
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Configurações do Playwright (opcional)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER=chromium

# Configurações da aplicação bancária (para produção)
BANK_APP_URL=https://exemplo-banco.com
BANK_API_KEY=...

# Configurações da LLM (para produção)
LLM_API_KEY=...
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
